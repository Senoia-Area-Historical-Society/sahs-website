rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for admin/curator/editor roles
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'catnolan@senoiahistory.com' || 
        request.auth.token.email.lower() == 'jeremywarren@senoiahistory.com' ||
        (exists(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())) &&
         get(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())).data.role == 'admin')
      );
    }

    function isCurator() {
      return request.auth != null && (
        isAdmin() || (
          exists(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())) &&
          get(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())).data.role == 'curator'
        )
      );
    }

    function isEditor() {
      return request.auth != null && (
        isCurator() || (
          exists(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())) &&
          get(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())).data.role == 'editor'
        )
      );
    }

    // Public Content: Anyone can read, Editors/Curators/Admins can write
    match /posts/{doc} { allow read: if true; allow write: if isEditor(); }
    match /galleries/{doc} { allow read: if true; allow write: if isEditor(); }
    match /historical_places/{doc} { allow read: if true; allow write: if isEditor(); }
    match /organization_entities/{doc} { allow read: if true; allow write: if isEditor(); }

    // Submissions: Public can ONLY create (useful for forms)
    match /submissions/{doc} {
      allow create: if true;
      allow read, update, delete: if isCurator();
    }

    // Bookings: Public can read CONFIRMED ones to see the calendar.
    // Creation is handled by Cloud Functions.
    match /bookings/{doc} {
      allow read: if resource.data.status == 'confirmed' || isCurator();
      allow write: if isCurator();
    }

    // Sensitive Data: Strictly Curators/Admins only
    match /memberships/{doc} { allow read, write: if isCurator(); }
    match /tickets/{doc} { allow read, write: if isCurator(); }
    
    // Internal Knowledge Base
    match /wiki/{doc} { allow read, write: if isEditor(); }

    // Volunteer Management
    // Sheets: public reads active ones; editors create/manage all
    match /volunteer_sheets/{sheetId} {
      allow read: if resource.data.status == 'active' || isEditor();
      allow create, update, delete: if isEditor();

      // Slots: public can read if parent sheet is active; editors manage
      match /slots/{slotId} {
        allow read: if get(/databases/$(database)/documents/volunteer_sheets/$(sheetId)).data.status == 'active' || isEditor();
        allow write: if isEditor();
      }

      // Registrations: anyone can create (anonymous signup); curators manage
      match /registrations/{regId} {
        allow create: if true;
        allow read, update, delete: if isCurator();
      }
    }

    // Mail (Trigger Email extension): deny all client access; extension service account bypasses rules
    match /mail/{doc} { allow read, write: if false; }

    // User Roles: Admins access only
    match /user_roles/{email} {
      allow read: if request.auth != null && isEditor();
      allow write: if request.auth != null && isAdmin();
    }

    // Default deny: Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
